generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Store {
  id                 String                @id @default(cuid())
  name               String
  address            String?
  phone              String?
  email              String?               @unique
  logoUrl            String?
  subscriptionStatus SubscriptionStatus    @default(TRIAL)
  subscriptionEndsAt DateTime?
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  storeType          StoreType             @default(SALES)
  categories         Category[]
  products           Product[]
  sales              Sale[]
  payments           SubscriptionPayment[]
  users              User[]
  debtors            Debtor[]

  @@map("stores")
}

model SubscriptionPayment {
  id        String   @id @default(cuid())
  storeId   String
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @default(now())
  validFrom DateTime
  validTo   DateTime
  notes     String?
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("subscription_payments")
}

model User {
  id                 String               @id @default(cuid())
  storeId            String?
  name               String
  phone              String?
  email              String?              @unique
  role               UserRole             @default(SALES_MANAGER)
  isActive           Boolean              @default(true)
  avatarUrl          String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  pin                String               @unique
  faceDescriptor     String?
  faceEnrolled       Boolean              @default(false)
  notification_reads notification_reads[]
  notifications      notifications[]
  sales              Sale[]
  store              Store?               @relation(fields: [storeId], references: [id])
  debtTransactions   DebtTransaction[]

  @@map("users")
}

model Category {
  id        String    @id @default(cuid())
  storeId   String
  name      String
  icon      String?
  createdAt DateTime  @default(now())
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([storeId, name])
  @@map("categories")
}

model Product {
  id          String     @id @default(cuid())
  storeId     String
  categoryId  String?
  name        String
  barcode     String?
  unit        UnitType   @default(PIECE)
  costPrice   Decimal    @db.Decimal(12, 2)
  sellPrice   Decimal    @db.Decimal(12, 2)
  stock       Decimal    @default(0) @db.Decimal(12, 3)
  minStock    Decimal    @default(5) @db.Decimal(12, 3)
  description String?
  imageUrl    String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  category    Category?  @relation(fields: [categoryId], references: [id])
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  saleItems   SaleItem[]

  @@unique([storeId, barcode])
  @@map("products")
}

model Sale {
  id             String        @id @default(cuid())
  storeId        String
  userId         String
  totalAmount    Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  paymentMethod  PaymentMethod @default(CASH)
  status         SaleStatus    @default(COMPLETED)
  customerName   String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  receiptNo      Int           @unique(map: "sales_receiptno_unique") @default(autoincrement())
  items          SaleItem[]
  store          Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id])

  @@map("sales")
}

model SaleItem {
  id         String  @id @default(cuid())
  saleId     String
  productId  String
  quantity   Decimal @db.Decimal(12, 3)
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)
  product    Product @relation(fields: [productId], references: [id])
  sale       Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model notification_reads {
  notificationId String
  userId         String
  readAt         DateTime?     @default(now()) @db.Timestamptz(6)
  notifications  notifications @relation(fields: [notificationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([notificationId, userId])
}

model notifications {
  id                 String               @id
  senderId           String
  title              String
  body               String
  target             String               @default("ALL")
  createdAt          DateTime?            @default(now()) @db.Timestamptz(6)
  notification_reads notification_reads[]
  users              User                 @relation(fields: [senderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Debtor {
  id           String            @id @default(cuid())
  storeId      String
  store        Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  totalDebt    Decimal           @default(0) @db.Decimal(12, 2)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  transactions DebtTransaction[]

  @@index([storeId])
  @@map("debtors")
}

model DebtTransaction {
  id        String          @id @default(cuid())
  storeId   String
  debtorId  String
  debtor    Debtor          @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?           @relation(fields: [userId], references: [id])
  type      DebtTxType
  amount    Decimal         @db.Decimal(12, 2)
  note      String?
  createdAt DateTime        @default(now())

  @@index([debtorId])
  @@index([storeId])
  @@index([userId])
  @@map("debt_transactions")
}

enum StoreType {
  SALES
  DEBT
}

enum DebtTxType {
  DEBT
  PAYMENT
}

enum UserRole {
  SUPER_ADMIN
  ROP
  SALES_MANAGER
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  BLOCKED
  TRIAL
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  INSTALLMENT
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

enum UnitType {
  PIECE
  KG
  LITER
  METER
  BOX
  SET
}
